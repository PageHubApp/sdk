{
  "name": "@pagehub/sdk",
  "version": "0.1.0",
  "description": "Embeddable visual page builder SDK — drop a full drag-and-drop page editor into any web app",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": [
    "*.css",
    "**/*.css",
    "src/index.ts",
    "src/editor.tsx",
    "src/css/vite-editor-css-entry.ts",
    "src/chrome/toolbar/inspector/RegistrySettings.tsx",
    "src/chrome/toolbar/inspector/registry/properties/register*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pagehub.js",
      "default": "./dist/pagehub.umd.cjs"
    },
    "./viewer": {
      "types": "./dist/viewer.d.ts",
      "import": "./dist/pagehub-viewer.js",
      "default": "./dist/pagehub-viewer.umd.cjs"
    },
    "./static-renderer": {
      "types": "./dist/static-renderer/index.d.ts",
      "import": "./dist/static-renderer/index.js"
    },
    "./editor.css": "./dist/editor.css",
    "./theme.css": "./src/css/theme.css",
    "./compile-css": "./src/compile-css.ts",
    "./presets/audio": "./src/components/Audio/Audio.presets.ts",
    "./presets/button": "./src/components/Button/Button.presets.ts",
    "./presets/container": "./src/components/Container/Container.presets.tsx",
    "./presets/form-element": "./src/components/FormElement/FormElement.presets.ts",
    "./presets/embed": "./src/components/Embed/Embed.presets.ts",
    "./presets/form": "./src/components/Form/Form.presets.tsx",
    "./presets/icon": "./src/components/Icon/Icon.presets.ts",
    "./presets/image": "./src/components/Image/Image.presets.ts",
    "./presets/link": "./src/components/Link/Link.presets.ts",
    "./presets/map": "./src/components/Map/Map.presets.ts",
    "./presets/text": "./src/components/Text/Text.presets.ts",
    "./presets/video": "./src/components/Video/Video.presets.ts",
    "./modifiers/button": "./src/components/Button/Button.modifiers.ts",
    "./modifiers/container": "./src/components/Container/Container.modifiers.ts",
    "./modifiers/form-element": "./src/components/FormElement/FormElement.modifiers.ts",
    "./modifiers/image": "./src/components/Image/Image.modifiers.ts",
    "./modifiers/link": "./src/components/Link/Link.modifiers.ts",
    "./modifiers/text": "./src/components/Text/Text.modifiers.ts",
    "./src/*": "./src/*"
  },
  "publishConfig": {
    "main": "./dist/pagehub.umd.cjs",
    "module": "./dist/pagehub.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build --config vite.editor-css.config.ts && pnpm run build:viewer && pnpm run build:demo-css",
    "build:editor-css": "vite build --config vite.editor-css.config.ts",
    "build:viewer": "vite build --mode viewer",
    "build:demo-css": "tailwindcss -i ./demo/tailwind.input.css -o ./demo/demo.tailwind.css --minify",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "demo": "vite --config vite.demo.config.ts"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/view": "^6.41.0",
    "@craftjs/core": "file:../../vendor/craftjs-core-0.2.27.tgz",
    "@craftjs/layers": "file:../../vendor/craftjs-layers-0.2.8.tgz",
    "@craftjs/utils": "file:../../vendor/craftjs-utils-0.2.7.tgz",
    "@floating-ui/react-dom": "^2.1.8",
    "@headlessui/react": "^2.2.10",
    "@hello-pangea/color-picker": "^3.2.2",
    "@lezer/highlight": "^1.2.3",
    "@pagehub/daisyui-spatial": "workspace:*",
    "@pagehub/ui": "workspace:*",
    "@radix-ui/react-select": "^2.2.6",
    "@tailwindcss/browser": "^4.2.2",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-bold": "^3.22.3",
    "@tiptap/extension-code": "^3.22.3",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-document": "^3.22.3",
    "@tiptap/extension-font-family": "^3.22.3",
    "@tiptap/extension-font-size": "3.0.0-next.3",
    "@tiptap/extension-highlight": "^3.22.3",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-italic": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-strike": "^3.22.3",
    "@tiptap/extension-subscript": "^3.22.3",
    "@tiptap/extension-superscript": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@uiw/react-codemirror": "^4.25.9",
    "@zedux/react": "^1.3.5",
    "auto-text-size": "^0.2.3",
    "css-tree": "^3.2.1",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "htmlparser2": "^9.1.0",
    "leaflet": "^1.9.4",
    "lodash.debounce": "^4.0.8",
    "lodash.throttle": "^4.1.1",
    "lzutf8": "^0.6.3",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "react-tooltip": "^5.30.1",
    "react-window": "^1.8.11",
    "react-youtube": "10.1.0",
    "slug": "^11.0.1",
    "style-to-object": "^1.0.14",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "use-eye-dropper": "^1.7.2",
    "uuid": "^10.0.0"
  },
  "optionalDependencies": {
    "prettier": "^3.8.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.7.0",
    "alpinejs": "3.14.9",
    "daisyui": "^5.5.19",
    "lodash-es": "^4.18.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "page-builder",
    "website-builder",
    "visual-editor",
    "drag-and-drop",
    "white-label",
    "embeddable",
    "sdk",
    "cms",
    "craftjs"
  ],
  "engines": {
    "node": ">=16"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pagehub-dev/sdk"
  },
  "homepage": "https://pagehub.dev",
  "bugs": {
    "url": "https://github.com/pagehub-dev/sdk/issues"
  }
}
