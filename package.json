{
  "name": "@pagehub/sdk",
  "version": "0.1.0",
  "description": "Embeddable visual page builder SDK — drop a full drag-and-drop page editor into any web app",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pagehub.js",
      "default": "./dist/pagehub.umd.cjs"
    },
    "./viewer": {
      "types": "./dist/viewer.d.ts",
      "import": "./dist/pagehub-viewer.js",
      "default": "./dist/pagehub-viewer.umd.cjs"
    },
    "./static-renderer": {
      "types": "./dist/static-renderer.d.ts",
      "import": "./dist/static-renderer.js"
    },
    "./editor.css": "./dist/editor.css",
    "./theme.css": "./src/css/theme.css",
    "./compile-css": "./src/compile-css.ts",
    "./src/*": "./src/*"
  },
  "publishConfig": {
    "main": "./dist/pagehub.umd.cjs",
    "module": "./dist/pagehub.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build --config vite.editor-css.config.ts && pnpm run build:viewer && pnpm run build:demo-css",
    "build:viewer": "vite build --mode viewer",
    "build:demo-css": "tailwindcss -i ./demo/tailwind.input.css -o ./demo/demo.tailwind.css --minify",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "demo": "vite --config vite.demo.config.ts"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/language": "^6.11.0",
    "@codemirror/lint": "^6.9.0",
    "@codemirror/view": "^6.38.6",
    "@craftjs/core": "^0.2.12",
    "@craftjs/layers": "^0.2.7",
    "@craftjs/utils": "^0.2.5",
    "@floating-ui/react-dom": "^2.1.8",
    "@headlessui/react": "^2.2.9",
    "@hello-pangea/color-picker": "^3.2.2",
    "@lezer/highlight": "^1.2.1",
    "@pagehub/daisyui-spatial": "workspace:*",
    "@pagehub/ui": "workspace:*",
    "@radix-ui/react-select": "^2.2.6",
    "@tailwindcss/browser": "^4.2.2",
    "@tiptap/core": "^3.6.5",
    "@tiptap/extension-color": "^3.6.5",
    "@tiptap/extension-document": "^3.6.5",
    "@tiptap/extension-font-family": "^3.6.5",
    "@tiptap/extension-font-size": "^3.0.0-next.3",
    "@tiptap/extension-highlight": "^3.6.5",
    "@tiptap/extension-image": "^3.6.5",
    "@tiptap/extension-link": "^3.6.5",
    "@tiptap/extension-placeholder": "^3.6.5",
    "@tiptap/extension-subscript": "^3.6.5",
    "@tiptap/extension-superscript": "^3.6.5",
    "@tiptap/extension-text-align": "^3.6.5",
    "@tiptap/extension-text-style": "^3.6.5",
    "@tiptap/pm": "^3.6.5",
    "@tiptap/react": "^3.6.5",
    "@tiptap/starter-kit": "^3.6.5",
    "@uiw/react-codemirror": "^4.25.2",
    "@zedux/react": "^1.3.5",
    "auto-text-size": "^0.2.3",
    "css-tree": "^3.2.1",
    "framer-motion": "^11.3.31",
    "gsap": "^3.14.2",
    "leaflet": "^1.9.4",
    "lodash.debounce": "^4.0.8",
    "lodash.throttle": "^4.1.1",
    "lzutf8": "^0.6.3",
    "react-icons": "^5.3.0",
    "react-leaflet": "^5.0.0",
    "react-tooltip": "^5.28.0",
    "react-window": "^1.8.11",
    "react-youtube": "10.1.0",
    "slug": "^11.0.1",
    "style-to-object": "^1.0.14",
    "tailwind-merge": "^3.5.0",
    "use-eye-dropper": "^1.6.4",
    "uuid": "^10.0.0"
  },
  "optionalDependencies": {
    "prettier": "^3.6.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "daisyui": "^5.5.18",
    "lodash-es": "^4.17.23",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "typescript": "^5.5.4",
    "vite": "^6.3.5",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.5.3"
  },
  "keywords": [
    "page-builder",
    "website-builder",
    "visual-editor",
    "drag-and-drop",
    "white-label",
    "embeddable",
    "sdk",
    "cms",
    "craftjs"
  ],
  "engines": {
    "node": ">=16"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pagehub-dev/sdk"
  },
  "homepage": "https://pagehub.dev",
  "bugs": {
    "url": "https://github.com/pagehub-dev/sdk/issues"
  }
}
