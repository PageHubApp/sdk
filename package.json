{
  "name": "@pagehub/sdk",
  "version": "0.1.0",
  "description": "Embeddable visual page builder SDK — drop a full drag-and-drop page editor into any web app",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./viewer": {
      "types": "./src/viewer.tsx",
      "import": "./src/viewer.tsx",
      "default": "./src/viewer.tsx"
    },
    "./static-renderer": {
      "types": "./src/static-renderer.ts",
      "import": "./src/static-renderer.ts",
      "default": "./src/static-renderer.ts"
    },
    "./editor.css": "./src/editor.css",
    "./config": "./src/config.ts",
    "./context": "./src/context.tsx",
    "./editor": "./src/editor.tsx",
    "./events": "./src/events.ts",
    "./tailwindBrowser": "./src/tailwindBrowser.ts",
    "./store": "./src/store.tsx",
    "./components/resolvers/*": "./src/components/resolvers/*",
    "./utils/tailwind/*": "./src/utils/tailwind/*",
    "./utils/data/*": "./src/utils/data/*",
    "./utils/design/*": "./src/utils/design/*",
    "./utils/hooks/*": "./src/utils/hooks/*",
    "./chrome/Viewport/*": "./src/chrome/Viewport/*",
    "./chrome/hooks/*": "./src/chrome/hooks/*",
    "./components/*": "./src/components/*",
    "./chrome/*": "./src/chrome/*",
    "./utils/*": "./src/utils/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build --config vite.editor-css.config.ts && pnpm run build:viewer && pnpm run build:demo-css",
    "build:viewer": "vite build --mode viewer",
    "build:demo-css": "pnpm exec @tailwindcss/cli -i ./demo/tailwind.input.css -o ./demo/demo.tailwind.css --minify",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "start:demo": "python3 -m http.server -d demo"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@craftjs/core": "^0.2.12",
    "@craftjs/layers": "^0.2.7",
    "@craftjs/utils": "^0.2.5",
    "@headlessui/react": "^2.2.9",
    "@pagehub/ui": "workspace:*",
    "@radix-ui/react-select": "^2.2.6",
    "@tailwindcss/browser": "^4.2.2",
    "@zedux/react": "^1.3.5",
    "boring-name-generator": "^1.0.3",
    "css-tree": "^3.2.1",
    "framer-motion": "^11.3.31",
    "lzutf8": "^0.6.3",
    "react-icons": "^5.3.0",
    "slug": "^11.0.1",
    "style-to-object": "^1.0.14"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "lodash-es": "^4.17.23",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "typescript": "^5.5.4",
    "vite": "^6.3.5",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.5.3"
  },
  "keywords": [
    "page-builder",
    "website-builder",
    "visual-editor",
    "drag-and-drop",
    "white-label",
    "embeddable",
    "sdk",
    "cms",
    "craftjs"
  ],
  "engines": {
    "node": ">=16"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pagehub-dev/sdk"
  },
  "homepage": "https://pagehub.dev"
}
