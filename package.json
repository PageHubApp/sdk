{
  "name": "@pagehub/sdk",
  "version": "0.1.5",
  "description": "Embeddable visual page builder SDK — drop a full drag-and-drop page editor into any web app, or render published sites anywhere JS runs.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": [
    "*.css",
    "**/*.css",
    "src/index.ts",
    "src/editor.tsx",
    "src/css/vite-editor-css-entry.ts",
    "src/chrome/toolbar/inspector/RegistrySettings.tsx",
    "src/chrome/toolbar/inspector/registry/properties/register*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/pagehub.js",
      "default": "./dist/pagehub.js"
    },
    "./react": {
      "types": "./dist/viewer.d.ts",
      "import": "./dist/pagehub-viewer.js",
      "default": "./dist/pagehub-viewer.js"
    },
    "./viewer": {
      "types": "./dist/viewer.d.ts",
      "import": "./dist/pagehub-viewer.js",
      "default": "./dist/pagehub-viewer.js"
    },
    "./html": {
      "types": "./dist/render/static/index.d.ts",
      "import": "./dist/render/static/index.js"
    },
    "./render/static": {
      "types": "./dist/render/static/index.d.ts",
      "import": "./dist/render/static/index.js"
    },
    "./editor.css": "./dist/editor.css",
    "./theme.css": "./src/css/theme.css",
    "./themes/shadcn.css": "./src/css/themes/shadcn.css",
    "./compile-css": "./src/compile-css/index.ts",
    "./presets/audio": "./src/components/Audio/Audio.presets.ts",
    "./presets/button": "./src/components/Button/Button.presets.ts",
    "./presets/container": "./src/components/Container/Container.presets.tsx",
    "./presets/form-element": "./src/components/FormElement/FormElement.presets.ts",
    "./presets/embed": "./src/components/Embed/Embed.presets.ts",
    "./presets/form": "./src/components/Form/Form.presets.tsx",
    "./presets/icon": "./src/components/Icon/Icon.presets.ts",
    "./presets/image": "./src/components/Image/Image.presets.ts",
    "./presets/link": "./src/components/Link/Link.presets.ts",
    "./presets/map": "./src/components/Map/Map.presets.ts",
    "./presets/text": "./src/components/Text/Text.presets.ts",
    "./presets/video": "./src/components/Video/Video.presets.ts",
    "./modifiers/button": "./src/components/Button/Button.modifiers.ts",
    "./modifiers/container": "./src/components/Container/Container.modifiers.ts",
    "./modifiers/form-element": "./src/components/FormElement/FormElement.modifiers.ts",
    "./modifiers/image": "./src/components/Image/Image.modifiers.ts",
    "./modifiers/link": "./src/components/Link/Link.modifiers.ts",
    "./modifiers/text": "./src/components/Text/Text.modifiers.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "main": "./dist/pagehub.js",
    "module": "./dist/pagehub.js",
    "types": "./dist/index.d.ts"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "!src/**/*.behavior.test.ts",
    "!src/**/*.behavior.test.tsx",
    "!src/**/__tests__",
    "!src/**/test-helpers",
    "!src/**/test-fixtures",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/**/*.spec.d.ts",
    "!dist/**/*.spec.d.ts.map",
    "!dist/**/*.behavior.test.d.ts",
    "!dist/**/*.behavior.test.d.ts.map",
    "!**/*.map"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build --config vite.editor-css.config.ts && pnpm run build:viewer && pnpm run build:static",
    "build:editor-css": "vite build --config vite.editor-css.config.ts",
    "build:viewer": "vite build --mode viewer",
    "build:static": "vite build --mode static",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
